# Nuxt dev server
NUXT_DEV_HOST=127.0.0.1
NUXT_DEV_PORT=3000

# Host used by Vite HMR websocket when running via custom local domain
NUXT_HMR_HOST=anduongliving.test

# Comma-separated hosts allowed by Vite dev server
NUXT_ALLOWED_HOSTS=anduongliving.test,127.0.0.1,localhost

# Upstream backend API (Botble/Laravel)
NUXT_API_BASE_URL=http://anduongliving.test/api
NUXT_API_KEY=

# Public site origin used for canonical URLs and internal URL normalization
NUXT_PUBLIC_SITE_URL=http://anduongliving.test

# Nuxt proxy origin for browser-side requests in local development
# Keep this as Nuxt dev server origin to avoid browser 404 on /api/cms/*
NUXT_PUBLIC_CMS_PROXY_BASE_URL=http://127.0.0.1:3000
